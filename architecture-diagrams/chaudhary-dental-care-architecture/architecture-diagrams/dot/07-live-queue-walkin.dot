digraph Queue {
  label="Live Queue & Walk-in Management (/dashboard/queue)";
  labelloc="t";
  fontname="Helvetica"; fontsize=16; bgcolor=white; rankdir=TB;
  node [shape=box, fontname="Helvetica", color=black, fontcolor=black];
  edge [color=black, fontname="Helvetica", fontcolor=black];

  doctor [shape=oval, label="Doctor"];
  load   [label="GET /api/appointments\n(today, doctor scope)"];
  db     [shape=cylinder, label="appointments"];
  cards  [label="Render queue cards\n(time · patient · service)"];
  overdue[shape=diamond, label="Past due\n(IST)?"];
  hl     [label="Highlight as overdue"];

  subgraph cluster_steps {
    label="4-step workflow stepper";
    fontname="Helvetica"; color=black;
    s1 [label="Waiting"];
    s2 [label="In Consultation"];
    s3 [label="In Treatment"];
    s4 [label="Done"];
    s1 -> s2 -> s3 -> s4 [label="PATCH /api/appointments/[id]"];
  }

  search [label="Patient search\nGET /api/patients/search"];
  walkin [label="Walk-in registration\nPOST /api/patients/walk-in"];

  doctor -> load -> db;
  db -> cards -> overdue;
  overdue -> hl [label="yes"];
  cards -> s1;
  doctor -> search;
  doctor -> walkin -> db;
}
