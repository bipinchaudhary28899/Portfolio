flowchart TD
    subgraph IN["Inputs"]
        T["Video title"]
        U["Uploader description"]
        TR["Whisper transcript<br/>(null if music/silent)"]
        VS["GPT-4o-mini visual summary<br/>(null if no frames)"]
    end

    S["GPT-4o-mini synthesis<br/>merge inputs into one rich paragraph"]
